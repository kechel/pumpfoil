<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Basis-Theme; die eigentlichen Compose-Farben kommen aus PumpfoilTheme.kt. -->
    <style name="Theme.Pumpfoil" parent="android:Theme.Material.NoActionBar" />

    <!-- Splash-Screen (core-splashscreen): kanonische Marken-Wellen (cyan) auf Brand-Navy. -->
    <color name="splash_navy">#020617</color>
    <color name="ic_launcher_background">#22D3EE</color>
    <style name="Theme.Pumpfoil.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_navy</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_waves</item>
        <item name="postSplashScreenTheme">@style/Theme.Pumpfoil</item>
    </style>
</resources>
