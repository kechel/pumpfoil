<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="Pumpfoil"
        android:supportsRtl="true"
        android:theme="@style/Theme.Pumpfoil">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="Pumpfoil"
            android:theme="@style/Theme.Pumpfoil.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Empfängt die needToken-Anfrage der Uhr (Companion-Pairing) und mintet/schiebt neu. -->
        <service
            android:name=".PhonePairingService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/pumpfoil/need-token" />
            </intent-filter>
        </service>
    </application>
</manifest>
