<?xml version="1.0" encoding="UTF-8"?>
<!--
  App-Settings (Garmin-Connect-Phone-App). Bewusst MINIMAL: nur der Pairing-Code.
  Datenfelder, Farbe und Vibrationsalarm werden auf pumpfoil.org konfiguriert und
  von der App per /api/devices/config geladen (siehe reloadConfig) — daher hier
  nicht mehr dupliziert. Hält die Settings-Seite leichtgewichtig.
-->
<settings>
  <setting propertyKey="@Properties.pairingCode" title="@Strings.SettingPairingCode" prompt="@Strings.SettingPairingCodePrompt">
    <settingConfig type="alphaNumeric" maxLength="8"/>
  </setting>
</settings>
