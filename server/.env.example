# Kopiere nach .env. Dev-Defaults nutzen SQLite — kein Postgres nötig.

# Prod: Postgres
# DATABASE_URL=postgresql+psycopg://foil:foil@localhost:5432/foil
DATABASE_URL=sqlite:///./foil.sqlite3

# In Prod MUSS ein starkes Secret gesetzt werden!
JWT_SECRET=dev-insecure-change-me
JWT_EXPIRE_HOURS=168

# Unveränderliche Roh-Session-Daten
DATA_DIR=./data

# Öffentliche Medien (Fotos, Profilbilder)
MEDIA_DIR=./media

# Gebautes Frontend (Prod). Im Dev leer lassen / Vite-Dev-Server nutzen.
WEB_DIST=../web/dist

# Öffentliche Basis-URL (Links in E-Mails + OAuth-Redirects)
BASE_URL=https://pumpfoil.org

# Optionale Alt-Domains -> 301 auf BASE_URL (kommagetrennt, /api ausgenommen)
# REDIRECT_HOSTS=alt-domain.example,www.alt-domain.example

# SMTP für Passwort-Reset-Mails. Leer -> Versand deaktiviert (Link wird geloggt).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Pumpfoil <noreply@pumpfoil.org>
SMTP_STARTTLS=1

# Kontakt-User-Agent für OSM/Overpass (Policy verlangt eine Kontaktangabe)
OSM_USER_AGENT=PumpfoilTracker/1.0 (+https://pumpfoil.org)

# Web-Push (VAPID). Schlüssel erzeugen z. B. mit py_vapid/pywebpush. Leer = Push aus.
# VAPID_PUBLIC_KEY=<base64url applicationServerKey>
# VAPID_PRIVATE_KEY_FILE=./vapid_private.pem
# VAPID_SUBJECT=mailto:noreply@pumpfoil.org

# OAuth-Provider (leer = deaktiviert). Redirect-URI je Provider:
#   {BASE_URL}/api/auth/oauth/<provider>/callback
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
# Apple „Sign in with Apple" (Web). client_secret wird NICHT statisch gesetzt, sondern
# vom Server aus dem .p8-Key signiert (ES256-JWT, auto-erneuert). Benötigt:
#   OAUTH_APPLE_CLIENT_ID = Services ID (NICHT die App-Bundle-ID!), z. B. org.pumpfoil.web
#   OAUTH_APPLE_TEAM_ID   = 10-stellige Apple Team ID
#   OAUTH_APPLE_KEY_ID    = Key ID des „Sign in with Apple"-Keys
#   OAUTH_APPLE_PRIVATE_KEY = Inhalt der .p8 (Zeilenumbrüche als \n)  ODER
#   OAUTH_APPLE_KEY_FILE  = Pfad zur .p8-Datei
# Bei Apple registrieren: Return URL {BASE_URL}/api/auth/oauth/apple/callback + Domain verifizieren.
# OAUTH_APPLE_CLIENT_ID=
# OAUTH_APPLE_TEAM_ID=
# OAUTH_APPLE_KEY_ID=
# OAUTH_APPLE_KEY_FILE=./apple_signin_key.p8
# OAUTH_STRAVA_CLIENT_ID=
# OAUTH_STRAVA_CLIENT_SECRET=
