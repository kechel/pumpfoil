{
  "configVersion": "v3",
  "app": {
    "appId": 1118995,
    "appName": "Pumpfoil",
    "appType": "app",
    "version": {
      "code": 4,
      "name": "1.0.1"
    },
    "icon": "icon.png",
    "vender": "pumpfoil.org",
    "description": "Pump foiling recorder — GPS + heart rate → pumpfoil.org"
  },
  "permissions": [
    "data:os.device.info",
    "device:os.local_storage",
    "device:os.geolocation",
    "device:os.heart_rate"
  ],
  "runtime": {
    "apiVersion": {
      "compatible": "3.0.0",
      "target": "3.0.0",
      "minVersion": "3.0"
    }
  },
  "targets": {
    "common": {
      "module": {
        "page": {
          "pages": [
            "page/index"
          ]
        },
        "app-side": {
          "path": "app-side/index"
        },
        "setting": {
          "path": "setting/index"
        }
      },
      "platforms": [
        {
          "st": "r",
          "dw": 480
        },
        {
          "st": "s",
          "dw": 390
        }
      ]
    }
  },
  "i18n": {
    "en-US": {
      "appName": "Pumpfoil"
    },
    "de-DE": {
      "appName": "Pumpfoil"
    }
  },
  "defaultLanguage": "en-US"
}
